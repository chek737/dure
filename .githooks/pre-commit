#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
project_dir="$repo_root/dure"

if [ -n "${DURE_PYTHON:-}" ]; then
    python_bin=$DURE_PYTHON
elif [ -n "${VIRTUAL_ENV:-}" ] && [ -x "$VIRTUAL_ENV/bin/python" ]; then
    python_bin="$VIRTUAL_ENV/bin/python"
elif [ -x "$repo_root/.venv/bin/python" ]; then
    python_bin="$repo_root/.venv/bin/python"
else
    python_bin=python3
fi

if ! command -v "$python_bin" >/dev/null 2>&1; then
    echo 'Python not found; set DURE_PYTHON or create .venv.' >&2
    exit 1
fi

if [ ! -d "$project_dir/src" ] || [ ! -d "$project_dir/tests" ]; then
    echo "Dure project not found at $project_dir." >&2
    exit 1
fi

git -C "$repo_root" diff --cached --check

staged=$(git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR)
if printf '%s\n' "$staged" | grep -Eq '(^|/)(\.env($|\.)|agent\.json$|server\.env$)|\.(deb|whl)$'; then
    echo 'Refusing to commit a secret/config or generated package artifact.' >&2
    exit 1
fi

if git -C "$repo_root" diff --cached | grep -Eq '^\+(<<<<<<<|=======|>>>>>>>)'; then
    echo 'Refusing to commit unresolved merge markers.' >&2
    exit 1
fi

"$python_bin" -m compileall -q "$project_dir/src" "$project_dir/tests"
